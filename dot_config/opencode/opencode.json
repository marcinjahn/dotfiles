{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.5",
  "small_model": "github-copilot/claude-haiku-4.5",
  "formatter": {
    "csharpier": {
      "command": ["dotnet", "csharpier", "format", "$FILE"],
      "extensions": [".cs", ".csproj", ".sln"]
    }
  },
  "share": "disabled",
  "permission": {
    "lsp": "allow",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "wc *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "find*": "allow",
      "sort*": "allow",
      "cp*": "allow",
      "cat *": "allow",
      "acli jira workitem view *": "allow",
      "jj diff*": "allow",
      "npm run build*": "allow",
      "npm run lint*": "allow",
      "npm run test*": "allow",
      "npm test": "allow",
      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "dotnet restore*": "allow",
      "ls *": "allow",
      "just build*": "allow",
      "just run*": "allow",
      "just test*": "allow",
      "cd *": "allow",
      "mkdir *": "allow"
    },
    "read": "allow"
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
